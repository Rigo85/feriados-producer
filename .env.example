NODE_ENV=development
LOG_LEVEL=info
PRODUCER_CRON=0 0 */12 * * *
TIMEZONE=America/Lima
HOLIDAYS_SOURCE_URL=https://www.gob.pe/feriados
HTTP_TIMEOUT_MS=15000
HTTP_MAX_RETRIES=3
USE_PLAYWRIGHT_FALLBACK=true
SNAPSHOT_RETENTION_DAYS=365
SCRAPE_RUN_RETENTION_DAYS=180
QUERY_TRACE_RETENTION_DAYS=90
REDIS_CACHE_TTL_SECONDS=172800
MAX_ALLOWED_MISSING_FUTURE_HOLIDAYS=2
MIN_OBSERVED_COVERAGE_RATIO=0.75
DATABASE_URL=postgres://user:pass@localhost:5432/feriados
REDIS_URL=redis://localhost:6379/0
PARSER_VERSION=2026-03-31.1
