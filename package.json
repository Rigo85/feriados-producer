{
  "name": "feriados-producer",
  "version": "0.1.0",
  "private": true,
  "description": "Productor de snapshots de feriados nacionales del Peru.",
  "type": "commonjs",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "migrate": "node dist/scripts/migrate.js",
    "once": "node dist/scripts/run-once.js",
    "cleanup": "node dist/scripts/cleanup-once.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:functional": "node --import tsx --test test/functional/**/*.test.ts",
    "test:unit": "node --import tsx --test test/unit/**/*.test.ts"
  },
  "dependencies": {
    "cheerio": "^1.1.0",
    "cron": "^3.3.1",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "playwright": "^1.51.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.11",
    "eslint": "^9.22.0",
    "@eslint/js": "^9.22.0",
    "globals": "^16.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
